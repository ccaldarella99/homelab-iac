# IDE
.vscode/

# --- General System Junk ---
*.log
*.tmp
.ansible/
.ssh/

# unused stuff
adguard/

# --- Secrets (CRITICAL) ---
# Never commit your Tailscale keys, passwords, or API tokens
*.env
secrets.yml
*.key
*.pem
inventory.ini
*.pub
secrets.*
ansible_key

# logs and databases
*.sqlite
*.db
*.log
uptime-kuma/uptime-kuma.db*
beszel/data.db*
homepage/logs/
crash.log

# --- fail2ban ---
# Ignore all except in config dir
fail2ban/
!fail2ban/config/

# --- Uptime Kuma ---
# Ignore the actual SQLite database and upload folder
uptime-kuma/uploads/
uptime-kuma/generator/
uptime-kuma/screenshots
uptime-kuma/kuma.db-shm
uptime-kuma/kuma.db-wal
uptime-kuma/kuma.db*

# --- Homarr ---
# Homarr stores its layout in a JSON/SQLite database
homarr/data/
homarr/configs/*.json
!homarr/configs/settings.json # Optional: keep basic settings but ignore layouts

# --- Beszel ---
beszel/key

# Terraform generated files
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
# CLI configuration file
.terraformrc
terraform.rc

# Ansible
# Ignore the retry files that get created on failure
*.retry
inventory/vault_pass.txt
ansible/inventory/hosts.ini

# Python cache
*/__pycache__
*.pyc

# Cache
.cache


# Windows thumbnail cache files
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db

# Dump file
*.stackdump

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Windows Installer files
*.cab
*.msi
*.msix
*.msm
*.msp

# Windows shortcuts
*.lnk


# macOS files
.DS_Store
._.DS_Store

